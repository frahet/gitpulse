# Copy this to .env and fill in values for your chosen providers

# ── AI Providers ──────────────────────────────────────────────────────────────
# Set the key for whichever provider you configure in gitpulse.yml

# Anthropic (provider: "anthropic")
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (provider: "openai")
# OPENAI_API_KEY=sk-...

# Google Gemini (provider: "google")
# GOOGLE_GENERATIVE_AI_API_KEY=...

# Mistral (provider: "mistral")
# MISTRAL_API_KEY=...

# ── Git Sources ───────────────────────────────────────────────────────────────
# GitHub personal access token (source: "github")
# Needs: repo (read) scope — https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_...

# GitLab personal access token (source: "gitlab")
# Needs: read_api scope — https://gitlab.com/-/user_settings/personal_access_tokens
# GITLAB_TOKEN=glpat-...

# ── Notifications ─────────────────────────────────────────────────────────────
# SMTP password (used if notifications.email.smtp_pass is not set in yml)
# SMTP_PASS=...

# ── Config ────────────────────────────────────────────────────────────────────
# Override config file path (default: ./gitpulse.yml)
# CONFIG_PATH=/path/to/gitpulse.yml

# Override SQLite database path (default: ./data/gitpulse.db)
# DB_PATH=/path/to/gitpulse.db
